<style>
   :root {
       --primary-bg-color: #ffffff;
       --secondary-bg-color: #f8f9fa;
       --primary-text-color: #212529;
       --secondary-text-color: #6c757d;
       --border-color: #dee2e6;
       --accent-color: #007bff;
       --shadow-color: rgba(0, 0, 0, 0.1);
   }

   .page-title {
       text-align: center;
       font-size: 2.5em;
       font-weight: 700;
       margin: 40px 0;
       color: var(--primary-text-color);
   }

   .movies-container {
       display: grid;
       grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
       gap: 25px;
       max-width: 1750px;
       padding: 0 24px;
       margin: 0 auto;
   }

   .movie-card {
       background-color: #ffffff;
       border-radius: 12px;
       overflow: hidden;
       transition: transform 0.3s ease, box-shadow 0.3s ease;
       display: flex;
       flex-direction: column;
       border: 1px solid var(--border-color);
       box-shadow: 0 4px 12px var(--shadow-color);
   }

   .movie-card:hover {
       transform: translateY(-8px);
       box-shadow: 0 12px 24px var(--shadow-color);
   }
   
   .poster-image {
       width: 100%;
       height: 330px;
       object-fit: cover;
   }

   .movie-card-content {
       padding: 16px;
       flex-grow: 1;
       display: flex;
       flex-direction: column;
   }

   .movie-title {
       font-size: 1.1em;
       font-weight: 600;
       margin: 0 0 8px 0;
       color: var(--primary-text-color);
       overflow: hidden;
       display: -webkit-box;
       -webkit-line-clamp: 2;
       -webkit-box-orient: vertical;
   }

   .movie-overview {
       font-size: 0.9em;
       color: var(--secondary-text-color);
       flex-grow: 1;
       margin-bottom: 16px;
       line-height: 1.5;
       overflow: hidden;
       display: -webkit-box;
       -webkit-line-clamp: 3;
       -webkit-box-orient: vertical;
   }

   .play-button {
       display: block;
       padding: 10px 15px;
       background-color: var(--accent-color);
       color: #fff;
       text-decoration: none;
       border-radius: 8px;
       text-align: center;
       margin-top: auto;
       font-weight: 500;
       transition: background-color 0.2s ease;
   }

   .play-button:hover {
       background-color: #0056b3;
   }

   /* Movies page: hide sidebar and make main full width (landscape theme) */
   #sidebar { display: none !important; }
   #main { width: 100% !important; float: none !important; }
</style>

<h1 class="page-title">电影中心</h1>
<div class="movies-container">
   <% movies.forEach(function(movie) { %>
       <div class="movie-card">
           <img class="poster-image" src="<%= movie.poster_path %>" alt="<%= movie.title %> Poster" onerror="this.src='/img/暂无封面.png'; this.onerror=null;">
           <div class="movie-card-content">
               <h3 class="movie-title"><%= movie.title %></h3>
               <p class="movie-overview"><%= movie.overview %></p>
               <a href="/player/?movie_id=<%= movie.id %>" target="_blank" class="play-button">立即播放</a>
           </div>
       </div>
   <% }); %>
</div>
