<style>
   /* Player page: hide sidebar and make main full width (landscape theme) */
   #sidebar { display: none !important; }
   #main { width: 100% !important; float: none !important; }
</style>

<!-- Plyr 样式 -->
<link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
<!-- 自定义样式 -->
<link rel="stylesheet" href="/player/style.css">

<div class="main-container">
    <!-- 左侧播放器和信息区 -->
    <div class="player-wrapper">
        <div class="player-container">
            <video id="player" playsinline controls></video>
        </div>
        <div class="movie-info">
            <h1 class="movie-title">正在加载...</h1>
            <p class="movie-details"></p>
            <div class="movie-overview-box">
                <h2>剧情简介</h2>
                <p class="movie-overview">正在加载...</p>
            </div>
        </div>
    </div>

    <!-- 右侧推荐列表 -->
    <div class="recommendations">
        <h3>接下来播放</h3>
        <!-- 推荐内容将由 script.js 动态填充 -->
    </div>
</div>

<!-- Hls.js 用于播放 m3u8 -->
<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<!-- Plyr.js 播放器 -->
<script src="https://cdn.plyr.io/3.7.8/plyr.js"></script>
<!-- 自定义脚本 -->
<script src="/player/script.js"></script>